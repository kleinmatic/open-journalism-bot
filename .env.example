# Open Journalism Bot - Environment Variables

# URL to CSV file containing GitHub accounts to monitor
CSV_URL=https://example.com/path/to/orgs.csv

# GitHub personal access token (optional, increases API rate limit from 60 to 5000 requests/hour)
GITHUB_TOKEN=

# Anthropic API key (optional, enables AI-generated descriptions for repos without descriptions)
ANTHROPIC_API_KEY=

# BlueSky credentials
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# How far back to look for new repos (in minutes)
CHECK_MINUTES=15

# Set to "true" to print posts to stdout instead of posting to BlueSky
TEST_MODE=true

# Developer alerts via Home Assistant (optional)
ALERT_HA_URL=http://homeassistant.local:8123
ALERT_HA_TOKEN=
ALERT_HA_NOTIFY_SERVICE=mobile_app_your_phone
